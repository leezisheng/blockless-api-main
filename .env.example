# blockless-api local config template.
# Copy this file to `.env` (same folder) and fill in the values:
#   cp .env.example .env      # or copy on Windows
# The real `.env` is gitignored; never commit secrets.

# Local dev Postgres. dev-up.ps1 starts a docker container `mpyhw-pg`
# (postgres:16) and publishes it on the host port in this URL.
# The password is required for local Docker startup.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55432/mpyhw
# Max pooled DB connections (psycopg_pool). Keep within the Postgres plan's connection cap.
MPYHW_DB_POOL_MAX=10

# Signs auth/credit JWTs. Any non-empty string for local dev.
MPYHW_JWT_SECRET=dev-local-secret-change-me

# Secret for GET /v1/admin/metrics (sent as X-Admin-Token). Empty = endpoint closed.
MPYHW_ADMIN_TOKEN=dev-admin-token

# Set to 1 ONLY when the app runs behind a trusted proxy that overwrites X-Forwarded-For
# (e.g. Render). Then per-IP rate limits key on the real client IP instead of the proxy.
# Leave unset locally: trusting the header without such a proxy lets clients spoof it.
MPYHW_TRUST_PROXY_HEADERS=0

# Global free-tier daily credit ceiling for /v1/llm/messages: once today's global spend
# would cross it, the route fail-fasts 503 global_credit_budget_exceeded. 0/unset disables
# the guard. Set to a real number in prod, tuned to the DeepSeek console cap.
MPYHW_DAILY_GLOBAL_BUDGET=0

# Backpressure on /v1/llm/messages: max concurrent in-flight turns globally and per user.
# Saturation fails fast (429 llm_busy), no queueing. 0 disables that dimension. Keep the
# global cap below the worker thread pool so streams can't starve other requests.
MPYHW_LLM_GLOBAL_CONCURRENCY=30
MPYHW_LLM_PER_USER_CONCURRENCY=2

# --- Inference & service mesh ------------------------------------------------
# Primary model path: the BlocklessCoder inference cluster (vLLM), reached over gRPC.
# When unset, the gateway falls back to the external provider below (dev convenience).
INFERENCE_GRPC_ENDPOINT=grpc://inference.blockless.svc:9000
# Hardware knowledge graph (Neo4j) + embedding store for grounded component retrieval.
KNOWLEDGE_GRAPH_URI=bolt://neo4j:7687
PGVECTOR_URL=postgresql://postgres:postgres@127.0.0.1:55432/kg_embeddings
# Pin-assignment constraint solver (OR-Tools CP-SAT / Z3) service.
CONSTRAINT_ROUTER_ENDPOINT=grpc://router.blockless.svc:9100
# Device simulation kernel (WASM + Verilator + ngspice co-sim) service.
SIM_KERNEL_ENDPOINT=grpc://sim.blockless.svc:9200
# Async pipeline: Celery broker (Redis Streams) + telemetry bus (Kafka).
REDIS_URL=redis://127.0.0.1:6379/0
KAFKA_BROKERS=127.0.0.1:9092

# External LLM provider used ONLY as a dev-time fallback when the inference cluster
# is unreachable (stub mode: $env:MPYHW_LLM_STUB = "1" needs no key).
DEEPSEEK_API_KEY=sk-...
MPYHW_LLM_MODEL=deepseek-chat

# Browser Google OAuth for `/ide/` sign-in. Required in production; optional locally
# unless testing the real Google callback flow instead of `/v1/auth/dev`.
MPYHW_PUBLIC_API_BASE=https://blockless-web-api.onrender.com
MPYHW_BROWSER_AUTH_REDIRECT_ORIGINS=https://block-less.com,http://127.0.0.1:8098
MPYHW_GOOGLE_CLIENT_ID=
MPYHW_GOOGLE_CLIENT_SECRET=
# Anonymous website recommendation (/v1/landing/recommend). All optional; defaults shown.
# Grounded retrieval path: capability extraction -> knowledge-graph lookup. With no
# inference endpoint (or provider fallback) configured the endpoint returns 503.
MPYHW_WEB_RECOMMEND_MAX_TOKENS=256
MPYHW_WEB_RECOMMEND_MAX_PARTS=4
MPYHW_WEB_RECOMMEND_TIMEOUT=10
MPYHW_WEB_RECOMMEND_RATE=10
MPYHW_WEB_RECOMMEND_WINDOW=60
# Global daily ceiling on LLM-backed recommend calls; past it the endpoint returns
# 503 llm_capacity (no degrade). Anonymous calls deduct no credits, so this bounds spend.
MPYHW_WEB_RECOMMEND_DAILY_LLM_CAP=2000
